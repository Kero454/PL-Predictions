# JWT Secret for token signing (generate a secure random string)
JWT_SECRET=your-super-secret-jwt-key-here

# Football Data API Key (get from https://www.football-data.org/)
FOOTBALL_API_KEY=your-football-data-org-api-key

# Server Configuration
PORT=3000
NODE_ENV=development

# ===== LOCAL DEV (SQLite) =====
# No additional database config needed — SQLite file created automatically.

# ===== PRODUCTION (Supabase + Vercel) =====
# Set these to use Supabase instead of SQLite:
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_KEY=eyJhbGci...your-service-role-key

# Push Notifications (VAPID keys — generate with: npx web-push generate-vapid-keys)
# VAPID_PUBLIC_KEY=your-vapid-public-key
# VAPID_PRIVATE_KEY=your-vapid-private-key
# VAPID_EMAIL=mailto:you@example.com

# Stripe (optional, for real payments)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Vercel Cron Secret (optional, protects cron endpoints)
# CRON_SECRET=your-random-cron-secret
