{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server.js"
    },
    {
      "src": "/socket\\.io/(.*)",
      "dest": "/server.js"
    },
    {
      "src": "/(.*\\.(js|css|svg|png|ico|json|webmanifest))",
      "dest": "/public/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/public/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/refresh-cache",
      "schedule": "*/3 * * * *"
    },
    {
      "path": "/api/cron/notifications",
      "schedule": "* * * * *"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
